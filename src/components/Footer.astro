---
import stats from "../data/stats.json";

// 建站日期：改成你的建站日
const LAUNCH = new Date("2025-08-20T00:00:00+08:00");
const days = Math.floor((Date.now() - LAUNCH.getTime()) / 86400000);

const thisYear = new Date().getFullYear();
const totalPosts = stats?.totalPosts ?? null;
const totalHuman =
	stats?.totalHumanReadable ??
	(typeof stats?.totalZhChars === "number" ? `${stats.totalZhChars} 字` : null);
---


<footer class="site-footer">
  <div class="footer-row">
    <span>自公元后第二个乙巳年启程，已走过 {days} 天</span>
    <span class="sep">/</span>
    <span>集 {totalPosts ?? "—"} 篇，合 {totalHuman ?? "—"}</span>
  </div>

<div class="footer-row">
    <span>最后落笔于 {stats.generatedAt}</span>
    <span class="sep">/</span>
    留存 <span class="footer-pv">—</span> 枚足迹，您是第 <span class="footer-uv">—</span> 位同行者
  </div>

  <div class="footer-row powered">
    <span>© 2025–{thisYear} LeeHenry</span>
    <span class="sep">/</span>
    <span>Licensed under <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/legalcode">CC BY-NC-SA 4.0</a></span>
    <!-- <span class="sep">/</span>
    <span><a href="https://beian.miit.gov.cn">琼ICP备2025060528号</a></span>
    <span class="sep">/</span> -->
    <!-- <a href="/rss.xml">RSS</a>
    <span class="sep">/</span>
    <a href="/sitemap-index.xml">Sitemap</a>
    <span class="sep">/</span> -->
    <!-- <span><a href="https://astro.build">Astro</a> × <a href="https://github.com/saicaca/fuwari">Fuwari</a></span> -->
    <!-- <span class="sep">/</span>
    <span>本站已加入 <a href="https://blogscn.fun/">BLOGS·CN</a></span> -->
    <span class="sep">/</span>
      <a href="https://xn--sr8hvo.ws/previous">←</a>
      🕸 <a href="https://xn--sr8hvo.ws">IndieWeb</a> 💍
      <a href="https://xn--sr8hvo.ws/next">→</a>
</footer>

<style>
  .site-footer {
    margin-top: 2rem;
    padding: 1.25rem 0 2rem;
    text-align: center;
    font-size: 0.93rem;
    color: var(--text-2, #9aa0a6);
  }
  .footer-row { margin: .25rem 0; line-height: 1.6; }
  .stats { color: var(--text-1, #e8eaed); }
  .powered { opacity: .9; }
  .sep { margin: 0 .5rem; opacity: .6; }
  .site-footer a { color: inherit; text-decoration: underline; text-underline-offset: 2px; }
</style>

<script>
(function() {
  function loadStats() {
    fetch('https://twikoo.leehenry.top/stats/')
      .then(function(r) { return r.json(); })
      .then(function(d) {
        document.querySelectorAll('.footer-pv').forEach(function(el) { el.textContent = d.pv ?? '—'; });
        document.querySelectorAll('.footer-uv').forEach(function(el) { el.textContent = d.uv ?? '—'; });
      })
      .catch(function() {});
  }
  loadStats();
  if (!window._statsListenerAdded) {
    window._statsListenerAdded = true;
    document.addEventListener('swup:page:view', loadStats);
  }
})();
</script>