---
import galleryData from "../data/gallery.json";

interface Props {
	class?: string;
	currentCategory?: string;
}

interface GalleryImage {
	src: string;
	category: string;
	w: number;
	h: number;
}

const className = Astro.props.class;
const currentCategory = Astro.props.currentCategory || "all";

const images = galleryData.images as GalleryImage[];
const filteredImages =
	currentCategory === "all"
		? images
		: images.filter((img) => img.category === currentCategory);

const allImagesData = JSON.stringify(galleryData.images);
const categoriesData = JSON.stringify(galleryData.categories);
---

<div class:list={["gallery-container", className]} id="gallery-container">
    <div class="gallery-masonry" id="gallery-masonry">
        {filteredImages.map((img, index) => (
            <div
                class="gallery-item"
                data-category={img.category}
                data-src={img.src}
            >
                <img
                    src={img.src}
                    width={img.w}
                    height={img.h}
                    alt={`摄影作品 ${index + 1}`}
                    loading="lazy"
                    decoding="async"
                />
            </div>
        ))}
    </div>
</div>

<script is:inline define:vars={{ allImagesData, categoriesData, currentCategory }}>
    window.__galleryData = {
        images: JSON.parse(allImagesData),
        categories: JSON.parse(categoriesData),
        currentCategory: currentCategory
    };
</script>

<script>
import PhotoSwipeLightbox from "photoswipe/lightbox";

function initGalleryLightbox() {
    const lightbox = new PhotoSwipeLightbox({
        gallery: '#gallery-masonry',
        children: '.gallery-item',
        pswpModule: () => import('photoswipe'),
        closeSVG: '<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#ffffff"><path d="M480-424 284-228q-11 11-28 11t-28-11q-11-11-11-28t11-28l196-196-196-196q-11-11-11-28t11-28q11-11 28-11t28 11l196 196 196-196q11-11 28-11t28 11q11 11 11 28t-11 28L536-480l196 196q11 11 11 28t-11 28q-11 11-28 11t-28-11L480-424Z"/></svg>',
        zoomSVG: '<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#ffffff"><path d="M340-540h-40q-17 0-28.5-11.5T260-580q0-17 11.5-28.5T300-620h40v-40q0-17 11.5-28.5T380-700q17 0 28.5 11.5T420-660v40h40q17 0 28.5 11.5T500-580q0 17-11.5 28.5T460-540h-40v40q0 17-11.5 28.5T380-460q-17 0-28.5-11.5T340-500v-40Zm40 220q-109 0-184.5-75.5T120-580q0-109 75.5-184.5T380-840q109 0 184.5 75.5T640-580q0 44-14 83t-38 69l224 224q11 11 11 28t-11 28q-11 11-28 11t-28-11L532-372q-30 24-69 38t-83 14Zm0-80q75 0 127.5-52.5T560-580q0-75-52.5-127.5T380-760q-75 0-127.5 52.5T200-580q0 75 52.5 127.5T380-400Z"/></svg>',
        padding: { top: 20, bottom: 20, left: 20, right: 20 },
        wheelToZoom: true,
        imageClickAction: 'close',
        tapAction: 'close',
        doubleTapAction: 'zoom',
        bgOpacity: 0.9,
    });

    lightbox.addFilter('domItemData', (itemData, element) => {
        const img = element.querySelector('img') as HTMLImageElement | null;
        if (img) {
            itemData.src = img.src;
            itemData.w = img.naturalWidth || img.width || window.innerWidth;
            itemData.h = img.naturalHeight || img.height || window.innerHeight;
            itemData.msrc = img.src;
        }
        return itemData;
    });

    lightbox.init();
    return lightbox;
}

function initCategoryFilter() {
    const categoryBtns = document.querySelectorAll('.gallery-category-btn');
    const galleryMasonry = document.getElementById('gallery-masonry');
    if (!categoryBtns.length || !galleryMasonry) return;

    categoryBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const category = (btn as HTMLElement).dataset.category;
            if (!category) return;

            galleryMasonry.querySelectorAll<HTMLElement>('.gallery-item').forEach(item => {
                item.style.display =
                    (category === 'all' || item.dataset.category === category) ? '' : 'none';
            });

            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    });
}

let lightbox: PhotoSwipeLightbox | null = null;

function init() {
    if (lightbox) lightbox.destroy();
    lightbox = initGalleryLightbox();
    initCategoryFilter();
}

init();

const setup = () => {
    window.swup?.hooks?.on('page:view', () => init());
    window.swup?.hooks?.on('content:replace', () => {
        if (lightbox) { lightbox.destroy(); lightbox = null; }
    }, { before: true });
};

if (window.swup) setup();
else document.addEventListener('swup:enable', setup);
</script>

<style>
    .gallery-container {
        width: 100%;
    }

    .gallery-masonry {
        column-count: 2;
        column-gap: 0.5rem;
    }

    @media (min-width: 1024px) {
        .gallery-masonry {
            column-count: 3;
        }
    }

    .gallery-item {
        break-inside: avoid;
        margin-bottom: 0.5rem;
        overflow: hidden;
        cursor: pointer;
    }

    .gallery-item img {
        width: 100%;
        height: auto;
        display: block;
        cursor: zoom-in;
        transition: transform 0.2s ease-in-out;
    }

    .gallery-item:hover img {
        transform: scale(1.05);
    }
</style>
