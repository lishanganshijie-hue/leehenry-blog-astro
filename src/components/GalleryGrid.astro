---
import galleryData from "../data/gallery.json";

interface Props {
	class?: string;
	currentCategory?: string;
}

interface GalleryImage {
	src: string;
	category: string;
}

const className = Astro.props.class;
const currentCategory = Astro.props.currentCategory || "all";

// 根据类别筛选图片
const filteredImages =
	currentCategory === "all"
		? galleryData.images
		: galleryData.images.filter((img) => img.category === currentCategory);

// 传递数据给客户端
const allImagesData = JSON.stringify(galleryData.images);
const categoriesData = JSON.stringify(galleryData.categories);
---

<div class:list={["gallery-container", className]} id="gallery-container">
    <div class="gallery-masonry" id="gallery-masonry">
        {filteredImages.map((img, index) => (
            <div 
                class="gallery-item" 
                data-category={img.category}
                data-src={img.src}
            >
                <img 
                    src={img.src}
                    alt={`摄影作品 ${index + 1}`}
                    loading="lazy"
                    decoding="async"
                    data-loaded="true"
                />
            </div>
        ))}
    </div>
</div>

<!-- 传递数据给客户端脚本 -->
<script is:inline define:vars={{ allImagesData, categoriesData, currentCategory }}>
    window.__galleryData = {
        images: JSON.parse(allImagesData),
        categories: JSON.parse(categoriesData),
        currentCategory: currentCategory
    };
</script>

<script>
import PhotoSwipeLightbox from "photoswipe/lightbox";

// 初始化灯箱
function initGalleryLightbox() {
    const lightbox = new PhotoSwipeLightbox({
        gallery: '#gallery-masonry',
        children: '.gallery-item',
        pswpModule: () => import('photoswipe'),
        closeSVG: '<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#ffffff"><path d="M480-424 284-228q-11 11-28 11t-28-11q-11-11-11-28t11-28l196-196-196-196q-11-11-11-28t11-28q11-11 28-11t28 11l196 196 196-196q11-11 28-11t28 11q11 11 11 28t-11 28L536-480l196 196q11 11 11 28t-11 28q-11 11-28 11t-28-11L480-424Z"/></svg>',
        zoomSVG: '<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#ffffff"><path d="M340-540h-40q-17 0-28.5-11.5T260-580q0-17 11.5-28.5T300-620h40v-40q0-17 11.5-28.5T380-700q17 0 28.5 11.5T420-660v40h40q17 0 28.5 11.5T500-580q0 17-11.5 28.5T460-540h-40v40q0 17-11.5 28.5T380-460q-17 0-28.5-11.5T340-500v-40Zm40 220q-109 0-184.5-75.5T120-580q0-109 75.5-184.5T380-840q109 0 184.5 75.5T640-580q0 44-14 83t-38 69l224 224q11 11 11 28t-11 28q-11 11-28 11t-28-11L532-372q-30 24-69 38t-83 14Zm0-80q75 0 127.5-52.5T560-580q0-75-52.5-127.5T380-760q-75 0-127.5 52.5T200-580q0 75 52.5 127.5T380-400Z"/></svg>',
        padding: { top: 20, bottom: 20, left: 20, right: 20 },
        wheelToZoom: true,
        imageClickAction: 'close',
        tapAction: 'close',
        doubleTapAction: 'zoom',
        bgOpacity: 0.9,
    });

    lightbox.addFilter('domItemData', (itemData, element) => {
        const img = element.querySelector('img');
        if (img) {
            itemData.src = img.src;
            itemData.w = img.naturalWidth || window.innerWidth;
            itemData.h = img.naturalHeight || window.innerHeight;
            itemData.msrc = img.src;
        }
        return itemData;
    });

    lightbox.init();
    return lightbox;
}

// 类别筛选功能
function initCategoryFilter() {
    const categoryBtns = document.querySelectorAll('.gallery-category-btn');
    const galleryMasonry = document.getElementById('gallery-masonry');
    
    if (!categoryBtns.length || !galleryMasonry) return;

    categoryBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            const category = btn.dataset.category;
            if (!category) return;

            // 筛选图片
            const items = galleryMasonry.querySelectorAll('.gallery-item');
            items.forEach(item => {
                const itemCategory = (item as HTMLElement).dataset.category;
                if (category === 'all' || itemCategory === category) {
                    (item as HTMLElement).style.display = '';
                    // 添加渐入动画
                    item.classList.remove('fade-in');
                    void (item as HTMLElement).offsetWidth; // 触发重排
                    item.classList.add('fade-in');
                } else {
                    (item as HTMLElement).style.display = 'none';
                }
            });

            // 滚动到页面顶部
            window.scrollTo({ top: 0, behavior: 'smooth' });
        });
    });
}

// 初始化
let lightbox: PhotoSwipeLightbox | null = null;

function init() {
    if (lightbox) {
        lightbox.destroy();
    }
    lightbox = initGalleryLightbox();
    initCategoryFilter();
}

// 页面加载时初始化
init();

// Swup 页面切换时重新初始化
const setup = () => {
    window.swup?.hooks?.on('page:view', () => {
        init();
    });
    window.swup?.hooks?.on('content:replace', () => {
        if (lightbox) {
            lightbox.destroy();
            lightbox = null;
        }
    }, { before: true });
};

if (window.swup) {
    setup();
} else {
    document.addEventListener('swup:enable', setup);
}
</script>

<style>
    .gallery-container {
        width: 100%;
    }

    .gallery-masonry {
        column-count: 2;
        column-gap: 0.5rem;
    }

    @media (min-width: 640px) {
        .gallery-masonry {
            column-count: 2;
            column-gap: 0.5rem;
        }
    }

    @media (min-width: 1024px) {
        .gallery-masonry {
            column-count: 3;
        }
    }

    .gallery-item {
        break-inside: avoid;
        margin-bottom: 0.5rem;
        position: relative;
        overflow: hidden;
        cursor: pointer;
        background-color: transparent;
    }

    .gallery-item img {
        width: 100%;
        height: auto;
        display: block;
        position: relative;
        z-index: 1;
        cursor: zoom-in;
        transition: transform 0.2s ease-in-out;
        opacity: 1;
        visibility: visible;
    }

    .gallery-item:hover img {
        transform: scale(1.05);
    }

    /* 筛选时的渐入动画 */
    .gallery-item.fade-in {
        animation: fadeIn 0.4s ease forwards;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
