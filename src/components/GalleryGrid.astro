---
import galleryData from "../data/gallery.json";

interface Props {
	class?: string;
	currentCategory?: string;
}

const className = Astro.props.class;
const currentCategory = Astro.props.currentCategory || "all";

const allImagesData = JSON.stringify(galleryData.images);
const categoriesData = JSON.stringify(galleryData.categories);
---

<div class:list={["gallery-container", className]} id="gallery-container">
    <div class="gallery-masonry" id="gallery-masonry"></div>
</div>

<script is:inline define:vars={{ allImagesData, categoriesData, currentCategory }}>
    window.__galleryData = {
        images: JSON.parse(allImagesData),
        categories: JSON.parse(categoriesData),
        currentCategory,
    };
</script>

<script>
import PhotoSwipeLightbox from "photoswipe/lightbox";

const BATCH = 12;
const GAP = 8; // 0.5rem in px，与 CSS gap 保持一致

type ImgData = { src: string; category: string; w: number; h: number };

let category = "all";
let offset = 0;
let colEls: HTMLElement[] = [];
let colHeights: number[] = []; // 各列已累积的像素高度（用于最短列优先）
let colWidth = 200;            // 列宽，用于将 h/w 比转换为像素高度
let lightbox: PhotoSwipeLightbox | null = null;

// ── 工具函数 ─────────────────────────────────────────────

function getColCount() {
    return window.innerWidth >= 1024 ? 3 : 2;
}

function getImages(cat: string): ImgData[] {
    const all = ((window.__galleryData as any)?.images ?? []) as ImgData[];
    return cat === "all" ? all : all.filter((img) => img.category === cat);
}

function makeItem(img: ImgData, idx: number): HTMLDivElement {
    const item = document.createElement("div");
    item.className = "gallery-item";
    item.dataset.category = img.category;
    item.dataset.src = img.src;

    const el = document.createElement("img");
    el.src = img.src;
    if (img.w) el.width = img.w;
    if (img.h) el.height = img.h;
    el.alt = `摄影作品 ${idx + 1}`;
    el.decoding = "async";
    item.appendChild(el);
    return item;
}

function makeBtn(): HTMLButtonElement {
    const btn = document.createElement("button");
    btn.className = "gallery-load-more";
    btn.id = "gallery-load-more";
    btn.type = "button";
    btn.setAttribute("aria-label", "继续浏览");
    // 与 PostCard 右侧按钮相同的图标：material-symbols:chevron-right-sharp
    btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
        <path fill="currentColor" d="M12.6 12L8 7.4L9.4 6l6 6l-6 6L8 16.6z"/>
    </svg>`;
    btn.addEventListener("click", loadMore);
    return btn;
}

/** 将元素放入最短列并更新列高度 */
function appendToShortest(el: HTMLElement, pixelHeight: number) {
    const idx = colHeights.indexOf(Math.min(...colHeights));
    colEls[idx].appendChild(el);
    colHeights[idx] += pixelHeight + GAP;
}

// ── 核心逻辑 ─────────────────────────────────────────────

function loadMore() {
    const imgs = getImages(category);
    const batch = imgs.slice(offset, offset + BATCH);
    if (!batch.length) return;

    document.getElementById("gallery-load-more")?.remove();

    batch.forEach((img, i) => {
        const itemH = img.h && img.w ? colWidth * (img.h / img.w) : colWidth;
        appendToShortest(makeItem(img, offset + i), itemH);
    });
    offset += batch.length;

    if (offset < imgs.length) {
        const lastIdx = colEls.length - 1;
        colEls[lastIdx].appendChild(makeBtn());
        colHeights[lastIdx] += colWidth * 0.75 + GAP;
    }

    if (lightbox) lightbox.destroy();
    lightbox = initLightbox();
}

function buildGallery(cat: string) {
    const masonry = document.getElementById("gallery-masonry");
    if (!masonry) return;

    category = cat;
    offset = 0;
    masonry.innerHTML = "";
    colEls = [];
    colHeights = [];

    const count = getColCount();
    const totalWidth = masonry.getBoundingClientRect().width || masonry.clientWidth || 600;
    colWidth = (totalWidth - GAP * (count - 1)) / count;

    for (let i = 0; i < count; i++) {
        const col = document.createElement("div");
        col.className = "gallery-col";
        masonry.appendChild(col);
        colEls.push(col);
        colHeights.push(0);
    }

    const imgs = getImages(cat);
    const batch = imgs.slice(0, BATCH);
    offset = batch.length;

    batch.forEach((img, i) => {
        const itemH = img.h && img.w ? colWidth * (img.h / img.w) : colWidth;
        appendToShortest(makeItem(img, i), itemH);
    });

    if (offset < imgs.length) {
        const lastIdx = colEls.length - 1;
        colEls[lastIdx].appendChild(makeBtn());
        colHeights[lastIdx] += colWidth * 0.75 + GAP;
    }

    if (lightbox) lightbox.destroy();
    lightbox = initLightbox();
}

// ── PhotoSwipe ────────────────────────────────────────────

function initLightbox(): PhotoSwipeLightbox {
    const lb = new PhotoSwipeLightbox({
        gallery: "#gallery-masonry",
        children: ".gallery-item",
        pswpModule: () => import("photoswipe"),
        closeSVG: '<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#ffffff"><path d="M480-424 284-228q-11 11-28 11t-28-11q-11-11-11-28t11-28l196-196-196-196q-11-11-11-28t11-28q11-11 28-11t28 11l196 196 196-196q11-11 28-11t28 11q11 11 11 28t-11 28L536-480l196 196q11 11 11 28t-11 28q-11 11-28 11t-28-11L480-424Z"/></svg>',
        zoomSVG: '<svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#ffffff"><path d="M340-540h-40q-17 0-28.5-11.5T260-580q0-17 11.5-28.5T300-620h40v-40q0-17 11.5-28.5T380-700q17 0 28.5 11.5T420-660v40h40q17 0 28.5 11.5T500-580q0 17-11.5 28.5T460-540h-40v40q0 17-11.5 28.5T380-460q-17 0-28.5-11.5T340-500v-40Zm40 220q-109 0-184.5-75.5T120-580q0-109 75.5-184.5T380-840q109 0 184.5 75.5T640-580q0 44-14 83t-38 69l224 224q11 11 11 28t-11 28q-11 11-28 11t-28-11L532-372q-30 24-69 38t-83 14Zm0-80q75 0 127.5-52.5T560-580q0-75-52.5-127.5T380-760q-75 0-127.5 52.5T200-580q0 75 52.5 127.5T380-400Z"/></svg>',
        padding: { top: 20, bottom: 20, left: 20, right: 20 },
        wheelToZoom: true,
        imageClickAction: "close",
        tapAction: "close",
        doubleTapAction: "zoom",
        bgOpacity: 0.9,
    });

    lb.addFilter("domItemData", (itemData, element) => {
        const img = element.querySelector("img") as HTMLImageElement | null;
        if (img) {
            itemData.src = img.src;
            itemData.w = img.naturalWidth || img.width || window.innerWidth;
            itemData.h = img.naturalHeight || img.height || window.innerHeight;
            itemData.msrc = img.src;
        }
        return itemData;
    });

    lb.init();
    return lb;
}

// ── 类别筛选 ──────────────────────────────────────────────

function initCategoryFilter() {
    document.querySelectorAll<HTMLElement>(".gallery-category-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
            buildGallery(btn.dataset.category ?? "all");
            window.scrollTo({ top: 0, behavior: "smooth" });
        });
    });
}

// ── 初始化 ────────────────────────────────────────────────

function init() {
    if (lightbox) lightbox.destroy();
    category = (window.__galleryData as any)?.currentCategory ?? "all";
    buildGallery(category);
    initCategoryFilter();
}

init();

const setup = () => {
    window.swup?.hooks?.on("page:view", () => init());
    window.swup?.hooks?.on("content:replace", () => {
        if (lightbox) { lightbox.destroy(); lightbox = null; }
    }, { before: true });
};

if (window.swup) setup();
else document.addEventListener("swup:enable", setup);
</script>

<!-- is:global 确保样式同时作用于 JS 动态创建的元素 -->
<style is:global>
    .gallery-masonry {
        display: flex;
        gap: 0.5rem;
        align-items: flex-start;
    }

    .gallery-col {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        min-width: 0; /* 防止 flex 子元素溢出 */
    }

    .gallery-item {
        overflow: hidden;
        cursor: pointer;
        flex-shrink: 0;
    }

    .gallery-item img {
        width: 100%;
        height: auto;
        display: block;
        cursor: zoom-in;
        transition: transform 0.2s ease-in-out;
    }

    .gallery-item:hover img {
        transform: scale(1.05);
    }

    /* 与 PostCard 无封面按钮样式一致：btn-regular + rounded-xl + enter-btn-bg */
    .gallery-load-more {
        width: 100%;
        aspect-ratio: 4 / 3;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--enter-btn-bg);
        border: none;
        cursor: pointer;
        color: var(--primary);  /* 图标颜色 */
        transition: background-color 0.15s ease, transform 0.15s ease;
    }

    .gallery-load-more:hover {
        background-color: var(--enter-btn-bg-hover);
    }

    .gallery-load-more:active {
        background-color: var(--enter-btn-bg-active);
        transform: scale(0.95);
    }

    .gallery-load-more svg {
        width: 2.25rem;  /* text-4xl */
        height: 2.25rem;
        transform: rotate(90deg); /* 向下指 */
    }
</style>
