---
import type { PageIntro } from "../data/page-intros";

interface Props {
	intro: PageIntro;
	class?: string;
}

const { intro, class: className = "" } = Astro.props;
---

<section class:list={["card-base px-6 md:px-9 py-6 onload-animation", className]}>
    <h1 class="text-2xl md:text-3xl font-bold text-90 mb-3">
        {intro.title}
        {intro.subtitle && (
            <span class="font-normal font-serif text-xl text-50"> · {intro.subtitle}</span>
        )}
    </h1>
    <div class="border-t border-dashed border-black/10 dark:border-white/[0.15] mb-4"></div>
    {intro.paragraphs.map((paragraph, i) => (
        <p class:list={["text-75 leading-relaxed", { "mt-3": i > 0 }]}>{paragraph}</p>
    ))}
    <slot name="stats" />
</section>
