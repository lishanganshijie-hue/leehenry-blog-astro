---
import type { CollectionEntry } from "astro:content";
import path from "node:path";
import { Icon } from "astro-icon/components";
import { titleSplitConfig } from "../config";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import { splitTitle } from "../utils/title-utils";
import { formatDateToYYYYMMDD } from "../utils/date-utils";
const formatDateToMMMDDYYYY = (date: Date) =>
	date.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
import { getDir } from "../utils/url-utils";
import ImageWrapper from "./misc/ImageWrapper.astro";
import PostMetadata from "./PostMeta.astro";
import PostStats from "./misc/PostStats.svelte";

interface Props {
	class?: string;
	entry: CollectionEntry<"posts">;
	title: string;
	url: string;
	published: Date;
	updated?: Date;
	tags: string[];
	category: string | null;
	image: string;
	description: string;
	draft: boolean;
	style: string;
}
const {
	entry,
	title,
	url,
	published,
	updated,
	tags,
	category,
	image,
	description,
	style,
} = Astro.props;
const className = Astro.props.class;

const hasCover = image !== undefined && image !== null && image !== "";

const coverWidth = "28%";

const { remarkPluginFrontmatter } = await entry.render();
const wordsK = (remarkPluginFrontmatter.words / 1000).toFixed(1) + 'k';

// 分割标题以支持细体+半透明显示
const titleParts = titleSplitConfig.enable ? splitTitle(title) : null;
const suffixOpacity = titleSplitConfig.opacity;
// 首页特殊样式配置
const showSuffix = titleSplitConfig.homePage.showSuffix;
const showOnHover = titleSplitConfig.homePage.showOnHover;
const hideSeparator = titleSplitConfig.homePage.hideSeparator;
const suffixScale = titleSplitConfig.homePage.suffixScale;
---
<div class:list={["group card-base flex flex-col-reverse md:flex-col w-full rounded-[var(--radius-large)] overflow-hidden relative", className]} style={style}>
    {tags.includes("🗃️当月事") && (
        <div class="pointer-events-none absolute -right-4 -top-4 text-[var(--primary)] opacity-10">
            <Icon name="material-symbols:flare" class="text-[7.5rem]" />
        </div>
    )}
    <div class:list={["pl-6 md:pl-9 pr-6 md:pr-9 pt-6 md:pt-7 pb-6 relative overflow-hidden", {"w-full": !hasCover, "w-full md:w-[calc(100%_-_var(--coverWidth)_-_12px)]": hasCover}]}>
        <a href={url}
           class="transition inline-flex items-center font-bold mb-1 text-2xl md:text-2xl text-90
        active:text-[var(--title-active)] dark:active:text-[var(--title-active)]
        pb-2 relative title-with-stroke
        after:absolute after:top-1/2 after:-translate-y-1/2 after:left-[-1rem] after:h-[1.1rem] after:bg-[var(--primary)] after:w-[0.4rem] after:opacity-100 after:transition-all after:duration-300 after:ease-out after:z-0
        group-hover:after:w-[calc(100%+1.9rem)] group-hover:after:opacity-30
        ">
            <span class="relative z-10">
                {titleParts ? (
                    <>
                        <span class="font-bold">{titleParts.prefix}</span>
                        {(showSuffix || showOnHover) && (
                            <span class="inline-block align-top title-suffix-wrapper transition-all duration-300 overflow-hidden" class:list={[{"max-w-0 opacity-0": !showSuffix && showOnHover}]} style={`max-width: ${showSuffix ? '100rem' : '0'}; opacity: ${showSuffix ? 1 : 0};`}>
                                {!hideSeparator && <span class="font-bold whitespace-nowrap">{titleParts.separator}</span>}
                                {" "}
                                <span class="font-normal inline-block whitespace-nowrap" style={`opacity: ${suffixOpacity}; font-size: ${suffixScale * 100}%;`}>{titleParts.suffix}</span>
                            </span>
                        )}
                    </>
                ) : (
                    title
                )}
            </span>
            <span class="absolute left-0 top-0 title-no-stroke inline-flex items-center">
                {titleParts ? (
                    <>
                        <span class="font-bold">{titleParts.prefix}</span>
                        {(showSuffix || showOnHover) && (
                            <span class="inline-block align-top title-suffix-wrapper transition-all duration-300 overflow-hidden" class:list={[{"max-w-0 opacity-0": !showSuffix && showOnHover}]} style={`max-width: ${showSuffix ? '100rem' : '0'}; opacity: ${showSuffix ? 1 : 0};`}>
                                {!hideSeparator && <span class="font-bold whitespace-nowrap">{titleParts.separator}</span>}
                                {" "}
                                <span class="font-normal inline-block whitespace-nowrap" style={`opacity: ${suffixOpacity}; font-size: ${suffixScale * 100}%;`}>{titleParts.suffix}</span>
                            </span>
                        )}
                    </>
                ) : (
                    title
                )}
            </span>
            <!-- <Icon class="inline text-[2rem] text-[var(--primary)] md:hidden translate-y-0.5 absolute" name="material-symbols:chevron-right-rounded" ></Icon> -->
            <!-- <Icon class="text-[var(--primary)] text-[2rem] transition hidden md:inline absolute translate-y-0.5 opacity-0 group-hover:opacity-100 -translate-x-1 group-hover:translate-x-0" name="material-symbols:chevron-right-rounded"></Icon> -->
        </a>

        <!-- metadata -->
        <!-- <PostMetadata published={published} updated={updated} tags={tags} category={category} hideTagsForMobile={true} hideUpdateDate={true} class="mb-4"></PostMetadata> -->

        <!-- description -->
        <div class:list={["transition text-75 mt-3 mb-6 text-base md:text-base text-center font-serif", {"line-clamp-2 md:line-clamp-1": !description}]}>
            { description || remarkPluginFrontmatter.excerpt }
        </div>

        <!-- divider -->
        <div class="border-t border-dashed border-black/10 dark:border-white/[0.15] mb-3"></div>

        <!-- word count and read time  -->
        <div class="text-sm flex transition items-center">
            <div class="flex gap-2 items-center">
                <span class="font-mono text-75">{formatDateToMMMDDYYYY(published)}</span>
                <span class="text-30">·</span>
                <span class="font-mono text-30">{wordsK} ch</span>
            </div>
            <div class="ml-auto hidden md:flex gap-2 items-center">
                <!-- <span class="text-black/30 dark:text-white/30">·</span> -->
                <!-- <span class="font-mono text-black/30 dark:text-white/30">{remarkPluginFrontmatter.minutes} {remarkPluginFrontmatter.minutes === 1 ? 'min' : 'mins'}</span> -->
                <PostStats path={url} client:visible />
            </div>
        </div>

    </div>

    {hasCover && <a href={url} aria-label={title}
                    class:list={["group",
                        "w-[calc(100%-3rem)] max-h-[20vh] md:max-h-none mx-6 mt-4 mb-0 md:mb-0 md:mx-0 md:mt-0",
                        "md:w-[var(--coverWidth)] relative md:absolute md:top-3 md:bottom-3 md:right-3 rounded-xl overflow-hidden active:scale-95"
                    ]} >
        <div class="absolute pointer-events-none z-10 w-full h-full group-hover:bg-black/30 group-active:bg-black/50 transition"></div>
        <div class="absolute pointer-events-none z-20 w-full h-full flex items-center justify-center ">
            <Icon name="material-symbols:chevron-right-rounded"
                  class="transition opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 text-white text-5xl">
            </Icon>
        </div>
        <ImageWrapper src={image} basePath={path.join("content/posts/", getDir(entry.id))} alt="Cover Image of the Post"
                  class="w-full h-full">
        </ImageWrapper>
    </a>}

</div>
<div class="transition border-t-[1px] border-dashed mx-6 border-black/10 dark:border-white/[0.15] last:border-t-0 md:hidden"></div>

<style define:vars={{coverWidth}}>
    .group:hover .title-suffix-wrapper {
        max-width: 100rem !important;
        opacity: 1 !important;
    }
    .title-with-stroke {
        -webkit-text-stroke: 0px var(--card-bg);
        text-stroke: 1px var(--card-bg);
    }
    .title-with-stroke::before {
        content: '';
        position: absolute;
        inset: -9999px;
        z-index: 0;
    }
    .title-with-stroke::after {
        filter: url(#xerox);
    }
    .title-no-stroke {
        -webkit-text-stroke: 0;
        text-stroke: 0;
        z-index: 20;
        pointer-events: none;
    }
</style>
