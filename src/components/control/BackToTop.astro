---
import { Icon } from "astro-icon/components";
---

<!-- There can't be a filter on parent element, or it will break `fixed` -->
<div class="back-to-top-wrapper">
    <div id="back-to-top-btn" class="back-to-top-btn hide flex items-center justify-center rounded-2xl overflow-visible transition" onclick="backToTop()">
        <!-- 方形边框进度条（连续笔画） -->
        <svg class="progress-border-svg" width="60" height="60" viewBox="0 0 60 60">
            <path
                id="progress-border-path"
                d="M 2 2 L 58 2 L 58 58 L 2 58 L 2 2"
                fill="none"
                stroke="var(--primary)"
                stroke-width="4"
                stroke-linecap="square"
                stroke-linejoin="round"
            />
        </svg>
        <button aria-label="Back to Top" class="btn-card h-[3.75rem] w-[3.75rem] relative z-10">
            <Icon name="material-symbols:rocket-outline" class="mx-auto"></Icon>
        </button>
    </div>
    <div id="scroll-to-comment-btn" class="scroll-to-comment-btn hide flex items-center rounded-2xl overflow-visible transition" onclick="scrollToComment()" style="display: none;">
        <svg class="progress-border-svg" width="60" height="60" viewBox="0 0 60 60">
            <path
                d="M 2 2 L 58 2 L 58 58 L 2 58 L 2 2"
                fill="none"
                stroke="var(--primary)"
                stroke-width="4"
                stroke-linecap="square"
                stroke-linejoin="round"
            />
        </svg>
        <button aria-label="Scroll to Comment" class="btn-card h-[3.75rem] w-[3.75rem] relative z-10">
            <Icon name="material-symbols:comic-bubble-outline-sharp" class="mx-auto"></Icon>
        </button>
    </div>
</div>

<style lang="stylus">
.back-to-top-wrapper
    position: fixed
    right: 1.5rem
    bottom: 1.5rem
    z-index: 50
    display: flex
    flex-direction: column
    gap: 0.5rem
    align-items: center
    pointer-events: none
    @media (max-width: 1023px)
        opacity: 0.35
        transition: opacity 0.3s ease
        &.mobile-active
            opacity: 1

.back-to-top-btn
    color: var(--primary)
    font-size: 2.25rem
    font-weight: bold
    border: none
    opacity: 1
    cursor: pointer
    transform: scale(1)
    pointer-events: auto
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease
    i
        font-size: 1.75rem
    &.hide
        transform: scale(0.9)
        opacity: 0
        pointer-events: none
    &:active
        transform: scale(0.9)

.progress-border-svg
    position: absolute
    top: 50%
    left: 50%
    transform: translate(-50%, -50%)
    width: 3.75rem
    height: 3.75rem
    pointer-events: none
    z-index: 20

#progress-border-path
    transition: stroke-dashoffset 0.1s linear

.scroll-to-comment-btn
    color: var(--primary)
    font-size: 2.25rem
    font-weight: bold
    border: none
    opacity: 1
    cursor: pointer
    transform: scale(1)
    pointer-events: auto
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease
    i
        font-size: 1.75rem
    &.hide
        transform: scale(0.9)
        opacity: 0
        pointer-events: none
    &:active
        transform: scale(0.9)

</style>

<script is:raw is:inline>
function backToTop() {
    window.scroll({ top: 0, behavior: 'smooth' });
}

function scrollToComment() {
    const commentSection = document.getElementById('comment-section');
    if (commentSection) {
        const offset = 100; // 距离顶部的偏移量，可以根据需要调整
        const elementPosition = commentSection.getBoundingClientRect().top;
        const offsetPosition = elementPosition + window.pageYOffset - offset;
        window.scroll({
            top: offsetPosition,
            behavior: 'smooth'
        });
    }
}

// 更新滚动进度条（连续笔画边框）
function updateScrollProgress() {
    const progressPath = document.getElementById('progress-border-path');
    if (!progressPath) return;

    // 初始化stroke-dasharray（如果还没有设置）
    if (!progressPath.getAttribute('stroke-dasharray')) {
        const pathLength = progressPath.getTotalLength();
        progressPath.setAttribute('stroke-dasharray', pathLength.toString());
        progressPath.setAttribute('stroke-dashoffset', pathLength.toString());
    }

    // 检测是否是文章页面
    const pathname = window.location.pathname;
    const postsMatch = pathname.match(/\/posts\/([^\/]+)/);
    const isPostPage = !!postsMatch;
    
    let progress = 0;
    
    if (isPostPage) {
        // 文章页面：只计算正文部分的滚动进度
        const postContainer = document.getElementById('post-container');
        const commentSection = document.getElementById('comment-section');
        
        if (postContainer) {
            const postContainerRect = postContainer.getBoundingClientRect();
            const postContainerTop = postContainerRect.top + window.pageYOffset;
            const postContainerHeight = postContainerRect.height;
            
            // 正文结束位置：如果存在评论区，则到评论区开始；否则到正文容器底部
            let contentEnd = postContainerTop + postContainerHeight;
            if (commentSection) {
                const commentSectionRect = commentSection.getBoundingClientRect();
                contentEnd = commentSectionRect.top + window.pageYOffset;
            }
            
            // 正文开始位置（考虑可能的偏移，比如banner）
            const contentStart = postContainerTop;
            const contentHeight = contentEnd - contentStart;
            
            // 当前滚动位置
            const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
            const windowHeight = window.innerHeight;
            
            // 计算正文部分的滚动进度
            // 当滚动位置在正文开始之前时，进度为0
            // 当滚动位置超过正文结束时，进度为1
            if (scrollTop < contentStart) {
                progress = 0;
            } else if (scrollTop + windowHeight > contentEnd) {
                progress = 1;
            } else {
                // 计算在正文范围内的滚动进度
                const scrolledInContent = scrollTop - contentStart;
                const scrollableContentHeight = contentHeight - windowHeight;
                progress = scrollableContentHeight > 0 
                    ? Math.min(scrolledInContent / scrollableContentHeight, 1) 
                    : 1;
            }
        } else {
            // 如果找不到post-container，回退到全页面计算
            const windowHeight = window.innerHeight;
            const documentHeight = document.documentElement.scrollHeight;
            const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
            const scrollableHeight = documentHeight - windowHeight;
            progress = scrollableHeight > 0 ? Math.min(scrollTop / scrollableHeight, 1) : 0;
        }
    } else {
        // 非文章页面：计算整个页面的滚动进度
        const windowHeight = window.innerHeight;
        const documentHeight = document.documentElement.scrollHeight;
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
        const scrollableHeight = documentHeight - windowHeight;
        progress = scrollableHeight > 0 ? Math.min(scrollTop / scrollableHeight, 1) : 0;
    }
    
    // 获取路径总长度
    const pathLength = progressPath.getTotalLength();
    
    // 根据进度计算stroke-dashoffset
    // 从完全隐藏（offset = pathLength）到完全显示（offset = 0）
    const offset = pathLength * (1 - progress);
    progressPath.style.strokeDashoffset = offset;
}

// 移动端点击 wrapper 临时激活（恢复不透明），2s 后还原
(function() {
    var wrapper = document.querySelector('.back-to-top-wrapper');
    var mobileActiveTimer = null;
    if (wrapper) {
        wrapper.addEventListener('touchstart', function() {
            wrapper.classList.add('mobile-active');
            clearTimeout(mobileActiveTimer);
            mobileActiveTimer = setTimeout(function() {
                wrapper.classList.remove('mobile-active');
            }, 2000);
        }, { passive: true });
    }
})();

// 根据当前路径显示/隐藏"跳转评论"按钮
function updateCommentButtonVisibility() {
    const scrollToCommentBtn = document.getElementById('scroll-to-comment-btn');
    if (scrollToCommentBtn) {
        const pathname = window.location.pathname;
        // 检查是否为文章页面（路径包含 /posts/ 且后面有内容）
        const postsMatch = pathname.match(/\/posts\/([^\/]+)/);
        const isPostPage = !!postsMatch;
        if (isPostPage) {
            scrollToCommentBtn.style.display = 'flex';
        } else {
            scrollToCommentBtn.style.display = 'none';
        }
    }
}

// 页面加载时执行
updateCommentButtonVisibility();
updateScrollProgress();

// 监听滚动事件
window.addEventListener('scroll', updateScrollProgress);
window.addEventListener('resize', updateScrollProgress);

// 在 Swup 页面切换后更新按钮状态
if (window.swup) {
    window.swup.hooks.on('page:view', () => {
        updateCommentButtonVisibility();
        // 延迟一下确保DOM已更新
        setTimeout(updateScrollProgress, 100);
    });
} else {
    document.addEventListener('swup:enable', () => {
        if (window.swup) {
            window.swup.hooks.on('page:view', () => {
                updateCommentButtonVisibility();
                setTimeout(updateScrollProgress, 100);
            });
        }
    });
}
</script>
