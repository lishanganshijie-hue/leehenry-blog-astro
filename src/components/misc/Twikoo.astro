---
import { siteConfig } from "../../config";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
const twikooConfig = siteConfig.twikoo;
---

{twikooConfig?.enable && (
<div class:list={["card-base rounded-[var(--radius-large)] overflow-hidden z-10 relative w-full mb-4 text-black/80 dark:text-white/80", className]} style="overflow: unset">
    <div class="px-6 md:px-9 py-6">
        <div id="tcomment" class="twikoo-comment"></div>
    </div>
    <script is:inline define:vars={{ twikooConfig }}>
        console.log('[Twikoo] 开始初始化...');
        console.log('[Twikoo] 配置信息:', twikooConfig);
        console.log('[Twikoo] 当前路径:', location.pathname);
        
        function initTwikoo() {
            console.log('[Twikoo] initTwikoo 函数被调用');
            console.log('[Twikoo] twikoo 对象存在:', !!window.twikoo);
            
            if (!window.twikoo) {
                console.error('[Twikoo] twikoo 对象未定义！');
                return;
            }
            
            const commentEl = document.getElementById('tcomment');
            console.log('[Twikoo] #tcomment 元素:', commentEl);
            
            if (!commentEl) {
                console.error('[Twikoo] #tcomment 元素不存在！');
                return;
            }
            
            try {
                console.log('[Twikoo] 调用 twikoo.init...');
                twikoo.init({
                    envId: twikooConfig.envId,
                    el: '#tcomment',
                    region: twikooConfig.region || '',
                    path: location.pathname,
                    lang: twikooConfig.lang || 'zh-CN',
                    onCommentLoaded: function() {
                        console.log('[Twikoo] 评论加载成功！');
                        if (window.createPhotoSwipe){
                            window.createPhotoSwipe()
                        }
                    }
                });
                console.log('[Twikoo] twikoo.init 调用完成');
            } catch (error) {
                console.error('[Twikoo] 初始化错误:', error);
            }
            
            // 防止 twikoo 内部 a 标签 href="#" 导致页面跳到顶部
            const commentContainer = document.getElementById("tcomment");
            if (commentContainer) {
                commentContainer.addEventListener("click", function (e) {
                    const selector = 'a[href="#"], svg, [class*="tk-action-"]';
                    const targetElement = e.target.closest(selector);
                    if (targetElement) {
                        e.preventDefault();
                        e.stopPropagation();
                    }
                });
            }
            if (window.createPhotoSwipe){
                // 动态创建样式并添加到页面
                const style = document.createElement('style');
                style.textContent = `
                    .tk-content img {
                        cursor: zoom-in;
                        transition: opacity 0.2s ease;
                    }
                    .tk-content img:hover {
                        opacity: 0.9;
                    }
                `;
                document.head.appendChild(style);
                console.log("[Twikoo] 动态样式已添加到页面");
            }
        }
        
        // https://twikoo.js.org/frontend.html CDN指南
        console.log('[Twikoo] 开始加载 twikoo.min.js...');
        const script = document.createElement('script');
        // 使用 jsDelivr CDN，更稳定可靠
        script.src = 'https://cdn.jsdelivr.net/npm/twikoo@1.6.44/dist/twikoo.all.min.js';
        script.onload = function() {
            console.log('[Twikoo] twikoo.min.js 加载成功');
            initTwikoo();
        };
        script.onerror = function(error) {
            console.error('[Twikoo] twikoo.min.js 加载失败:', error);
            console.error('[Twikoo] 尝试使用备用 CDN...');
            // 备用 CDN：unpkg
            const fallbackScript = document.createElement('script');
            fallbackScript.src = 'https://unpkg.com/twikoo@1.6.44/dist/twikoo.all.min.js';
            fallbackScript.onload = function() {
                console.log('[Twikoo] 备用 CDN 加载成功');
                initTwikoo();
            };
            fallbackScript.onerror = function() {
                console.error('[Twikoo] 所有 CDN 都加载失败，请检查网络或考虑自托管');
            };
            document.head.appendChild(fallbackScript);
        };
        document.head.appendChild(script);
        console.log('[Twikoo] script 标签已添加到页面');
    </script>
</div>
)}
