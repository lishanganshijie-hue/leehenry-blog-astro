---
import { siteConfig } from "../../config";

interface Props {
	class?: string;
}

const { class: className } = Astro.props;
const twikooConfig = siteConfig.twikoo;
---

{twikooConfig?.enable && (
<div class:list={["card-base twikoo-container rounded-[var(--radius-large)] overflow-hidden z-10 px-6 md:px-9 pt-6 pb-4 relative w-full mb-4 text-black/80 dark:text-white/80", className]} style="overflow: unset">
    <div id="tcomment" class="twikoo-comment"></div>
    <script is:inline define:vars={{ twikooConfig }}>
        function initTwikoo() {
            twikoo.init({
                envId: twikooConfig.envId,
                el: '#tcomment',
                region: twikooConfig.region || '',
                path: location.pathname,
                lang: twikooConfig.lang || 'zh-CN',
                onCommentLoaded: function() {
                    console.log('Twikoo comments loaded successfully');
                    if (window.createPhotoSwipe){
                        window.createPhotoSwipe()
                    }
                    initEmojiZoom();
                }
            });
            // 防止 twikoo 内部 a 标签 href="#" 导致页面跳到顶部
            // todo: 不知道为啥会导致页面跳到顶部，暂时先用这种方式解决
            // Prevent Twikoo's internal <a href="#"> tags from causing the page to scroll to the top.
            const commentContainer = document.getElementById("twikoo");
            if (commentContainer) {
                commentContainer.addEventListener("click", function (e) {
                    const selector = 'a[href="#"], svg, [class*="tk-action-"]';
                    const targetElement = e.target.closest(selector);
                    if (targetElement) {
                        e.preventDefault();
                        e.stopPropagation();
                    }
                });
            }
            // 图片样式已移至 twikoo.css 统一管理
            if (window.createPhotoSwipe){
                // PhotoSwipe 相关逻辑保持不变
            }
        }

        // 表情放大：挂在 document 上，不依赖 Twikoo 加载时序
        (function initEmojiZoom() {
            if (window._tkEmojiZoom) return;
            window._tkEmojiZoom = true;

            const SCALE = 3;
            let overlay = null;
            let hideTimer = null;

            document.addEventListener('mouseover', function(e) {
                const img = e.target;
                if (!(img instanceof HTMLImageElement)) return;
                if (!img.closest('.tk-content p')) return;

                // 取消正在进行的收起动画
                if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
                if (overlay) { overlay.remove(); overlay = null; }

                const rect = img.getBoundingClientRect();
                const w = rect.width * SCALE;
                const h = rect.height * SCALE;

                // 以原图中心为基准定位
                let left = rect.left + rect.width / 2 - w / 2;
                let top  = rect.top  + rect.height / 2 - h / 2;
                left = Math.max(8, Math.min(left, window.innerWidth  - w - 8));
                top  = Math.max(8, Math.min(top,  window.innerHeight - h - 8));

                overlay = document.createElement('img');
                overlay.src = img.src;
                overlay.setAttribute('aria-hidden', 'true');
                overlay.style.cssText =
                    'position:fixed;left:' + left + 'px;top:' + top + 'px;' +
                    'width:' + w + 'px;height:' + h + 'px;' +
                    'z-index:9999;pointer-events:none;' +
                    'filter:drop-shadow(0 2px 12px rgba(0,0,0,0.3));' +
                    'transform:scale(' + (1 / SCALE) + ');' +
                    'transform-origin:center center;' +
                    'transition:transform 0.12s ease;';
                document.body.appendChild(overlay);

                // 触发过渡
                requestAnimationFrame(function() {
                    requestAnimationFrame(function() {
                        if (overlay) overlay.style.transform = 'scale(1)';
                    });
                });
            });

            // 滚动时立即销毁
            window.addEventListener('scroll', function() {
                if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
                if (overlay) { overlay.remove(); overlay = null; }
            }, { passive: true });

            document.addEventListener('mouseout', function(e) {
                const img = e.target;
                if (!(img instanceof HTMLImageElement)) return;
                if (!img.closest('.tk-content p')) return;
                if (!overlay) return;

                // 缩回后再移除
                overlay.style.transform = 'scale(' + (1 / SCALE) + ')';
                var el = overlay;
                hideTimer = setTimeout(function() {
                    el.remove();
                    if (overlay === el) overlay = null;
                    hideTimer = null;
                }, 120);
            });
        })();
        // https://twikoo.js.org/frontend.html CDN指南
        // 多CDN源级联加载策略
        const cdnSources = [
            { name: 'unpkg (主CDN)', url: 'https://unpkg.com/twikoo@1.6.44/dist/twikoo.all.min.js' },
            { name: 'npmmirror (中国)', url: 'https://registry.npmmirror.com/twikoo/1.6.44/files/dist/twikoo.min.js' },
            { name: 'zstatic (中国)', url: 'https://s4.zstatic.net/npm/twikoo@1.6.44/dist/twikoo.min.js' },
            { name: 'jsDelivr (全球)', url: 'https://cdn.jsdelivr.net/npm/twikoo@1.6.44/dist/twikoo.min.js' },
            { name: 'zstatic备用', url: 'https://s4.zstatic.net/ajax/libs/twikoo/1.6.41/twikoo.min.js' },
            { name: 'baomitu备用', url: 'https://lib.baomitu.com/twikoo/1.6.39/twikoo.min.js' }
        ];
        
        let currentCdnIndex = 0;
        
        function loadTwikooScript() {
            if (currentCdnIndex >= cdnSources.length) {
                console.error('[Twikoo] 所有 CDN 源均加载失败，请检查网络连接');
                return;
            }
            
            const cdn = cdnSources[currentCdnIndex];
            console.log('[Twikoo] 尝试加载 CDN [' + (currentCdnIndex + 1) + '/' + cdnSources.length + ']: ' + cdn.name);
            console.log('[Twikoo] CDN URL: ' + cdn.url);
            
            const script = document.createElement('script');
            script.src = cdn.url;
            
            script.onload = function() {
                console.log('[Twikoo] ✓ CDN 加载成功: ' + cdn.name);
                initTwikoo();
            };
            
            script.onerror = function(error) {
                console.warn('[Twikoo] ✗ CDN 加载失败: ' + cdn.name);
                currentCdnIndex++;
                if (currentCdnIndex < cdnSources.length) {
                    console.log('[Twikoo] 切换到下一个 CDN 源...');
                    loadTwikooScript();
                } else {
                    console.error('[Twikoo] 所有 CDN 源均已尝试，加载失败');
                }
            };
            
            document.head.appendChild(script);
        }
        
        // 开始加载
        console.log('[Twikoo] 开始加载 Twikoo 脚本...');
        loadTwikooScript();
    </script>
</div>
)}
