---
import { Icon } from "astro-icon/components";
import { profileConfig } from "../../config";
import { url } from "../../utils/url-utils";
import ImageWrapper from "../misc/ImageWrapper.astro";

const config = profileConfig;
const fallbackQR = "/wechat-qrcode.png";
---

<div class="card-base p-3 h-card">
  <a class="u-url u-uid hidden" href="https://leehenry.top" rel="me"></a>
  <img class="u-photo hidden" src={config.avatar || ""} alt="" />
  <a
    aria-label="Go to About Page"
    href={url('/about/')}
    class="group block relative mx-auto mt-1 lg:mx-0 lg:mt-0 mb-3
           max-w-[12rem] lg:max-w-none overflow-hidden rounded-xl active:scale-95"
  >
    <div
      class="absolute transition pointer-events-none group-hover:bg-black/30 group-active:bg-black/50
             w-full h-full z-50 flex items-center justify-center"
    >
      <Icon
        name="material-symbols:home-outline"
        class="transition opacity-0 scale-90 group-hover:scale-100 group-hover:opacity-100 text-white text-5xl"
      />
    </div>
    {config.avatarLight ? (
      <>
        <ImageWrapper
          src={config.avatarLight}
          alt="Profile Image of the Author"
          class="mx-auto lg:w-full h-full lg:mt-0 dark:hidden"
          noFade={true}
        />
        <ImageWrapper
          src={config.avatar || ""}
          alt="Profile Image of the Author"
          class="mx-auto lg:w/full h/full lg:mt-0 hidden dark:block"
          noFade={true}
        />
      </>
    ) : (
      <ImageWrapper
        src={config.avatar || ""}
        alt="Profile Image of the Author"
        class="mx-auto lg:w-full h/full lg:mt-0 "
        noFade={true}
      />
    )}
  </a>

  <div class="px-2">
    <div class="font-bold text-xl text-center mb-1 dark:text-neutral-50 transition relative signature-container">
      <!-- 移动端和平板端：始终显示文字 -->
      <span class="lg:hidden p-name">{config.name}</span>
      <!-- PC端：根据配置显示签名图片或文字 -->
      {config.useSignature && config.signatureDark ? (
        <>
          {/* 亮色模式：img 占位撑开尺寸，绝对定位 div 用 alpha mask 显示 primary 色 */}
          <div class="signature-img hidden lg:block dark:lg:hidden relative" data-no-fade>
            <img src={config.signatureDark} alt="" class="invisible w-full" />
            <div class="absolute inset-0" style={`background: var(--primary); mask-image: url('${config.signatureDark}'); -webkit-mask-image: url('${config.signatureDark}'); mask-size: contain; -webkit-mask-size: contain; mask-repeat: no-repeat; -webkit-mask-repeat: no-repeat; mask-position: center; -webkit-mask-position: center;`} />
          </div>
          {/* 暗色模式：原图显示 */}
          <img src={config.signatureDark} alt="Signature" class="signature-img hidden lg:hidden dark:lg:block" data-no-fade />
        </>
      ) : (
        <span class="hidden lg:inline p-name">{config.name}</span>
      )}
    </div>
    <div class="h-1 w-5 bg-[var(--primary)] mx-auto mb-2 transition"></div>
    <div class="text-center text-neutral-400 mb-2.5 transition p-note">{config.bio}</div>

    <!-- 社交图标：支持 popup（弹二维码） -->
    <div class="flex gap-3 justify-center mb-1 relative" style="z-index: 100;">
      {
        config.links.length > 1
          ? config.links.map((item) => (
              item?.popup
                ? (
                  <span class="social-tip-wrap">
                    <button
                      type="button"
                      aria-label={item.name}
                      class="btn-regular h-8 w-8 active:scale-90"
                      data-qr-trigger
                      data-qr-src={item.popupImage ?? fallbackQR}
                    >
                      <Icon name={item.icon} class="text-[1rem]" />
                    </button>
                    <span class="social-tip">{item.name}</span>
                  </span>
                )
                : item?.copyOnClick
                ? (
                  <span class="social-tip-wrap">
                    <button
                      type="button"
                      aria-label={item.name}
                      class="btn-regular h-8 w-8 active:scale-90 social-copy-btn"
                      data-copy-url={item.url}
                    >
                      <Icon name={item.icon} class="text-[1rem] copy-btn-main-icon transition" />
                      <svg viewBox="0 -960 960 960" xmlns="http://www.w3.org/2000/svg" class="text-[1.2rem] copy-btn-check-icon transition absolute opacity-0 w-[1.2rem] h-[1.2rem]">
                        <path d="m389-377.13 294.7-294.7q12.58-12.67 29.52-12.67 16.93 0 29.61 12.67 12.67 12.68 12.67 29.53 0 16.86-12.28 29.14L419.07-288.41q-12.59 12.67-29.52 12.67-16.94 0-29.62-12.67L217.41-430.93q-12.67-12.68-12.79-29.45-.12-16.77 12.55-29.45 12.68-12.67 29.62-12.67 16.93 0 29.28 12.67L389-377.13Z" />
                      </svg>
                    </button>
                    <span class="social-tip" data-tip-default={item.name} data-tip-copied="已复制">{item.name}</span>
                  </span>
                )
                : (
                  <span class="social-tip-wrap">
                    <a
                      rel="me"
                      aria-label={item.name}
                      href={item.url}
                      target="_blank"
                      class="btn-regular h-8 w-8 active:scale-90"
                    >
                      <Icon name={item.icon} class="text-[1rem]" />
                    </a>
                    <span class="social-tip">{item.name}</span>
                  </span>
                )
            ))
          : (
            config.links[0]?.popup
              ? (
                <button
                  type="button"
                  aria-label={config.links[0].name}
                  class="btn-regular h-10 gap-3 px-3 font-bold active:scale-95"
                  data-qr-trigger
                  data-qr-src={config.links[0].popupImage ?? fallbackQR}
                >
                  <Icon name={config.links[0].icon} class="text-[1rem]" />
                  {config.links[0].name}
                </button>
              )
              : (
                <a
                  rel="me"
                  aria-label={config.links[0].name}
                  href={config.links[0].url}
                  target="_blank"
                  class="btn-regular h-10 gap-2 px-3 font-bold active:scale-95"
                >
                  <Icon name={config.links[0].icon} class="text-[1rem]" />
                  {config.links[0].name}
                </a>
              )
          )
      }
    </div>
  </div>
</div>

<!-- 弹窗 -->
<dialog id="profile-qr-modal" class="modal">
  <div id="profile-qr-content" class="modal-card">
    <img id="profile-qr-img"
         src="/wechat-qrcode.png"
         alt="二维码"
         class="qr-img" />
    <div class="btn-row">
      <button type="button" id="profile-qr-close" class="btn-close">关闭</button>
    </div>
  </div>
</dialog>

<script is:inline>
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.social-copy-btn');
    if (!btn) return;
    var url = btn.getAttribute('data-copy-url');
    if (!url) return;
    navigator.clipboard.writeText(url);

    var timeoutId = btn._copyTimeout;
    if (timeoutId) clearTimeout(timeoutId);

    var tip = btn.closest('.social-tip-wrap')?.querySelector('.social-tip');
    btn.classList.add('copy-success');
    if (tip) tip.textContent = tip.getAttribute('data-tip-copied');

    btn._copyTimeout = setTimeout(function() {
      btn.classList.remove('copy-success');
      if (tip) tip.textContent = tip.getAttribute('data-tip-default');
    }, 1500);
  });

  function initQRModal() {
    const modal = document.getElementById('profile-qr-modal');
    const content = document.getElementById('profile-qr-content');
    const img = document.getElementById('profile-qr-img');
    const closeBtn = document.getElementById('profile-qr-close');

    if (!modal || !content || !img) {
      console.warn('QR modal elements not found');
      return;
    }

    // 打开
    document.addEventListener('click', (e) => {
      const btn = e.target.closest?.('[data-qr-trigger]');
      if (!btn) return;
      e.preventDefault();
      e.stopPropagation();

      const src = btn.getAttribute('data-qr-src') || '/wechat-qrcode.png';
      img.setAttribute('src', src);

      modal.showModal();
      modal.classList.remove('is-closing');
      // 强制 reflow
      content.offsetHeight;
      modal.classList.add('is-open');
    });

    // 关闭
    function animateClose() {
      if (!modal.open) return;
      modal.classList.remove('is-open');
      modal.classList.add('is-closing');
    }

    if (closeBtn) {
      closeBtn.addEventListener('click', animateClose);
    }

    // 点击遮罩关闭
    modal.addEventListener('click', (e) => {
      const r = content.getBoundingClientRect();
      if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) {
        animateClose();
      }
    });

    // 动画结束时真正关闭
    content.addEventListener('transitionend', (ev) => {
      if (ev.propertyName === 'opacity' && modal.classList.contains('is-closing')) {
        modal.close();
        modal.classList.remove('is-closing', 'is-open');
      }
    });

    // 页面离开时兜底关闭
    window.addEventListener('pagehide', () => {
      if (modal.open) modal.close();
      modal.classList.remove('is-open', 'is-closing');
    });
  }

  // 确保 DOM 加载完成后再初始化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initQRModal);
  } else {
    initQRModal();
  }
</script>

<style is:global>
  /* 基础 */
  .modal {
    padding: 0;
    border: none;
    background: transparent;
    pointer-events: none;
  }
  .modal[open] {
    display: grid;
    place-items: center;
    inset: 0;
    pointer-events: auto;
  }

  /* 背景 */
  .modal::backdrop { background: rgba(0,0,0,0); }
  .modal.is-open::backdrop {
    animation: backdrop-in 220ms cubic-bezier(.2,.8,.2,1) forwards;
  }
  .modal.is-closing::backdrop {
    animation: backdrop-out 200ms ease-in forwards;
  }
  @keyframes backdrop-in   { from { background: rgba(0,0,0,0); } to { background: rgba(0,0,0,.5); } }
  @keyframes backdrop-out  { from { background: rgba(0,0,0,.5); } to { background: rgba(0,0,0,0); } }

  /* 内容卡片 */
  .modal-card {
    max-width: min(90vw, 420px);
    width: 100%;
    margin: 0 16px;
    background: var(--card-bg, white);
    color: inherit;
    padding: 1rem 1rem 0.875rem;
    box-shadow: 0 10px 30px rgba(0,0,0,.25);

    transform: scale(.96);
    opacity: 0;
    transition: transform 220ms cubic-bezier(.2,.8,.2,1), opacity 220ms ease-out;
    will-change: transform, opacity;
  }
  .modal.is-open .modal-card {
    transform: scale(1);
    opacity: 1;
  }
  .modal.is-closing .modal-card {
    transform: scale(.96);
    opacity: 0;
    transition-duration: 180ms;
  }

  /* 图片与按钮 */
  .qr-img { display:block; width:100%; height:auto; max-height:80vh; object-fit:contain; background:transparent; border-radius: 0; }
  .btn-row { display:flex; justify-content:center; margin-top:0.875rem; }
  .btn-close { padding:0.5rem 1rem; background:var(--primary); color:#fff; cursor:pointer; }

  /* RSS 复制按钮图标切换 */
  .social-copy-btn {
    position: relative;
    transition: background-color 0.15s;
  }
  .social-copy-btn .copy-btn-check-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0;
    transition: opacity 0.15s;
    fill: white;
  }
  .social-copy-btn .copy-btn-main-icon {
    transition: opacity 0.15s;
  }
  .social-copy-btn.copy-success {
    background-color: var(--primary) !important;
  }
  .social-copy-btn.copy-success .copy-btn-main-icon {
    opacity: 0;
  }
  .social-copy-btn.copy-success .copy-btn-check-icon {
    opacity: 1;
  }

  /* 社交按钮 Tooltip */
  .social-tip-wrap {
    position: relative;
    display: inline-flex;
  }
  .social-tip {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-bottom: 6px;
    padding: 0.3rem 0.6rem;
    background: var(--card-bg);
    color: var(--btn-content);
    border: 1px solid var(--btn-card-bg-active);
    border-radius: var(--radius-medium);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
    font-size: 0.8rem;
    font-family: var(--font-sans);
    font-weight: normal;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.18s ease-in-out, visibility 0.18s ease-in-out;
    z-index: 200;
  }
  .social-tip-wrap:hover .social-tip {
    opacity: 1;
    visibility: visible;
  }

  /* 签名图片样式 */
  .signature-container {
    overflow: visible;
  }
  /* 只在桌面端显示签名图片 */
  .signature-img {
    max-width: 80%;
    height: auto;
    object-fit: contain;
    margin: 0 auto;
    transform: translateY(-75%);
    position: relative;
    z-index: 60;
    margin-bottom: -40%;
  }
  /* 移动端和平板端隐藏签名图片，避免布局问题 */
  @media (max-width: 1023px) {
    .signature-img {
      display: none !important;
    }
  }
</style>
