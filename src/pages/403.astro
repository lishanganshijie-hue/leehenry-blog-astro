		color: var(--btn-content);
		margin: 0 0 0.4rem 0;
	}

	.error-desc {
		font-size: 0.875rem;
		color: var(--btn-content);
		opacity: 0.55;
		margin: 0 0 1.5rem 0;
	}

	.error-back {
