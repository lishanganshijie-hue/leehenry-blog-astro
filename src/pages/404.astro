---
import Layout from "@layouts/Layout.astro";
---

<Layout title="404 - 页面不见了">
	<div class="error-page">
		<div class="error-content">
			<pre class="ascii-art">
░█░█░█░█░█░█░░░░░░░░█░░░█▀▀░█▀▀░█░█░█▀▀░█▀█░█▀▄░█░█░░░░░░░░▀█▀░█▀█░█▀█░
░█▄█░█▄█░█▄█░░░░░░░░█░░░█▀▀░█▀▀░█▀█░█▀▀░█░█░█▀▄░░█░░░░░░░░░░█░░█░█░█▀▀░
░▀░▀░▀░▀░▀░▀░░░▀░░░░▀▀▀░▀▀▀░▀▀▀░▀░▀░▀▀▀░▀░▀░▀░▀░░▀░░░░▀░░░░░▀░░▀▀▀░▀░░░</pre>
			<div class="error-text">
				<p class="error-title"><strong><em>404 Not Found</em></strong></p>
				<p class="error-desc">您访问的内容已经消失，或者从未存在过。</p>
				<a href="/" class="error-back">✦ 回到安全的地方 ✦</a>
			</div>
		</div>
	</div>
</Layout>

<style>
	.error-page {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		background-color: var(--page-bg);
		background-image: radial-gradient(circle, rgba(0, 0, 0, 0.1) 1px, transparent 1px);
		background-size: 28px 28px;
	}

	:global(.dark) .error-page {
		background-image: radial-gradient(circle, rgba(255, 255, 255, 0.07) 1px, transparent 1px);
	}

	.error-content {
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.ascii-art {
		color: var(--primary);
		font-size: clamp(0.3rem, 1.2vw, 0.65rem);
		line-height: 1.15;
		margin: 0 0 2rem 0;
		text-align: center;
		overflow: hidden;
	}

	.error-text {
		text-align: center;
	}

	.error-title {
		font-size: 0.875rem;
		color: var(--btn-content);
		margin: 0 0 0.4rem 0;
	}

	.error-desc {
		font-size: 0.875rem;
		color: var(--btn-content);
		opacity: 0.55;
		margin: 0 0 1.5rem 0;
	}

	.error-back {
		font-size: 0.875rem;
		color: var(--btn-content);
		opacity: 0.55;
		text-decoration: none;
		transition: opacity 0.15s;
	}

	.error-back:hover {
		opacity: 1;
	}
</style>
