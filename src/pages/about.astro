---
import { getEntry, render } from "astro:content";
import LikeButton from "@components/misc/LikeButton.svelte";
import Markdown from "@components/misc/Markdown.astro";
import PageIntroCard from "@components/PageIntroCard.astro";
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { pageIntros } from "../data/page-intros";

const intro = pageIntros.about;

const aboutPost = await getEntry("spec", "about");
if (!aboutPost) {
	throw new Error("About page content not found");
}

const { Content, headings: rawHeadings } = await render(aboutPost);
// TOC 仅取 H2 及以下；H1 已不存在于 about.md（已迁入介绍卡）
const headings = rawHeadings.filter((h) => h.depth > 1);
---

<MainGridLayout
    title={intro.title}
    description={intro.paragraphs[0]}
    headings={headings}
>
    <div class="flex flex-col gap-4">
        <!-- 介绍卡片 -->
        <PageIntroCard intro={intro} />

        <!-- 内容卡片：about.md 正文 + 点赞 -->
        <section class="card-base px-4 md:px-9 py-6 onload-animation">
            <Markdown class="mt-0">
                <Content />
            </Markdown>
            <LikeButton client:load />
        </section>
    </div>
</MainGridLayout>
