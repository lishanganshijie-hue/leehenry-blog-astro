---
import ArchivePanel from "@components/ArchivePanel.svelte";
import Heatmap from "@components/widget/Heatmap.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPostsList } from "../utils/content-utils";

const sortedPostsList = await getSortedPostsList();

function pickDateLike(data: any) {
	const cand =
		data?.published ??
		data?.date ??
		data?.pubDate ??
		data?.created ??
		data?.updated;
	if (!cand) return null;
	const d = new Date(cand);
	return isNaN(d.getTime()) ? null : d;
}

// 用类型守卫去掉 null/非法日期，再映射为 YYYY-MM-DD 字符串
const dateSet = new Set(
	(sortedPostsList ?? [])
		.map((p: any) => pickDateLike(p?.data))
		.filter((d): d is Date => d instanceof Date && !isNaN(d.getTime())),
);

const dates: string[] = Array.from(dateSet, (d) =>
	d.toISOString().slice(0, 10),
);
---

<MainGridLayout title={i18n(I18nKey.archive)}>
  <section class="archive-heatmap">
    <Heatmap dates={dates} client:only="svelte" cell={9} gap={2} />
  </section>

  <ArchivePanel sortedPosts={sortedPostsList} client:only="svelte" />
</MainGridLayout>

<style>
  .archive-heatmap { 
    margin-bottom: 20px; 
    display: none; /* 默认隐藏（移动端和平板端） */
  }
  @media (min-width: 1024px) { 
    .archive-heatmap { 
      display: block; /* 桌面端显示 */
      margin-bottom: 20px; 
    } 
  }
</style>
