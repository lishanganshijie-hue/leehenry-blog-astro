---
import PageIntroCard from "@components/PageIntroCard.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getGuestPostsByAuthor } from "@utils/content-utils";
import { url } from "@utils/url-utils";
import { getGuestAuthor } from "../../data/guest-authors";
import { pageIntros } from "../../data/page-intros";

const intro = pageIntros.guests;
const groups = await getGuestPostsByAuthor();
const totalPosts = groups.reduce((sum, g) => sum + g.posts.length, 0);

const authorCards = groups.map((group) => ({
	group,
	meta: getGuestAuthor(group.author),
	authorUrl: url(`/guests/${group.author}/`),
}));
---

<MainGridLayout title={intro.title} description={intro.paragraphs[0]}>
    <div class="flex flex-col gap-4">
        <!-- 顶部介绍卡片 -->
        <PageIntroCard intro={intro}>
            <div slot="stats" class="mt-4 text-50 text-sm">
                当前共 <span class="text-[var(--primary)] font-medium">{groups.length}</span> 位作者，<span class="text-[var(--primary)] font-medium">{totalPosts}</span> 篇字句。
            </div>
        </PageIntroCard>

        <!-- 作者卡片：只保留标题入口 -->
        {authorCards.map(({ group, meta, authorUrl }, idx) => (
            <section
                class="card-base px-6 md:px-9 py-6 onload-animation"
                style={`animation-delay: calc(var(--content-delay) + ${(idx + 1) * 60}ms);`}
            >
                <div class="flex items-baseline gap-3 flex-wrap">
                    <a
                        href={authorUrl}
                        aria-label={`查看 ${meta.name} 的全部字句`}
                        class="author-title-link group/title relative inline-flex items-center text-2xl md:text-3xl font-bold text-90 uppercase tracking-wide pb-1 transition
                            after:absolute after:top-1/2 after:-translate-y-1/2 after:left-[-0.8rem] after:h-[1.05rem] after:bg-[var(--primary)] after:w-[0.3rem] after:opacity-100 after:transition-all after:duration-300 after:ease-out after:-z-10
                            hover:after:w-[calc(100%+1.5rem)] hover:after:opacity-30 hover:text-90"
                    >
                        <span class="relative z-10">{meta.name}</span>
                    </a>
                    {meta.signature && (
                        <span class="text-50 text-sm font-serif truncate">
                            {meta.signature}
                        </span>
                    )}
                    <span class="text-50 text-sm whitespace-nowrap ml-auto">
                        {group.posts.length} 篇
                    </span>
                </div>
            </section>
        ))}
    </div>
</MainGridLayout>

<style>
    .author-title-link::after {
        filter: url(#xerox);
    }
</style>
