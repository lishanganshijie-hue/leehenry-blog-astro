---
import path from "node:path";
import License from "@components/misc/License.astro";
import LikeButton from "@components/misc/LikeButton.svelte";
import Markdown from "@components/misc/Markdown.astro";
import Twikoo from "@components/misc/Twikoo.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { getSortedPosts } from "@utils/content-utils";
import { getDir, getPostUrlBySlug } from "@utils/url-utils";
import { Icon } from "astro-icon/components";
import { licenseConfig } from "src/config";
import ImageWrapper from "../../components/misc/ImageWrapper.astro";
import PostMetadata from "../../components/PostMeta.astro";
import {
	postMetaConfig,
	profileConfig,
	siteConfig,
	titleSplitConfig,
} from "../../config";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";
import { splitTitle } from "../../utils/title-utils";

export async function getStaticPaths() {
	const blogEntries = await getSortedPosts();
	return blogEntries.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content, headings: rawHeadings } = await entry.render();

const AI_LEVELS = {
	0: { label: "手自一心", range: "0~5% AI",   icon: "material-symbols:volunteer-activism-sharp", varName: "ai-badge-0" },
	1: { label: "执一驭万", range: "5~20% AI",  icon: "material-symbols:swords-sharp",             varName: "ai-badge-1" },
	2: { label: "借舟渡海", range: "20~50% AI", icon: "material-symbols:sailing-sharp",            varName: "ai-badge-2" },
} as const;
const headings = rawHeadings.filter(h => h.slug !== 'footnote-label');

const { remarkPluginFrontmatter } = await entry.render();

// 分割标题以支持细体+半透明显示
const titleParts = titleSplitConfig.enable
	? splitTitle(entry.data.title)
	: null;
const nextTitleParts =
	titleSplitConfig.enable && entry.data.nextTitle
		? splitTitle(entry.data.nextTitle)
		: null;
const prevTitleParts =
	titleSplitConfig.enable && entry.data.prevTitle
		? splitTitle(entry.data.prevTitle)
		: null;
const suffixOpacity = titleSplitConfig.opacity;
// 正文页特殊样式配置
const suffixNewLine = titleSplitConfig.postPage.suffixNewLine;

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: entry.data.title,
	description: entry.data.description || entry.data.title,
	keywords: entry.data.tags,
	author: {
		"@type": "Person",
		name: profileConfig.name,
		url: Astro.site,
	},
	datePublished: formatDateToYYYYMMDD(entry.data.published),
	inLanguage: entry.data.lang
		? entry.data.lang.replace("_", "-")
		: siteConfig.lang.replace("_", "-"),
	// TODO include cover image here
};
---
<MainGridLayout banner={entry.data.image} title={entry.data.title} description={entry.data.description} lang={entry.data.lang} setOGTypeArticle={true} headings={headings}>
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)}></script>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4">
        <div id="post-container" class:list={["card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full h-entry",
            {}
        ]}>
            <a class="u-url u-uid hidden" href={Astro.url.href}></a>
            <time class="dt-published hidden" datetime={entry.data.published.toISOString()}>{formatDateToYYYYMMDD(entry.data.published)}</time>
            <span class="p-author hidden">{profileConfig.name}</span>

            {entry.data.aiUsage && (() => {
                const ai = AI_LEVELS[entry.data.aiUsage.level];
                const badgeStyle = `--badge-bg: var(--${ai.varName}-bg); --badge-content: var(--${ai.varName}-content);`;
                return (
                <div class="ai-mark" style={badgeStyle}>
                    <div class="ai-mark-body">
                        <Icon name={ai.icon} class="ai-mark-icon text-[1.1rem] flex-none" />
                        <span class="ai-mark-text">{ai.label}</span>
                    </div>
                    <div class="ai-mark-tip">
                        <div class="ai-tip-level">{ai.label}<span class="ai-tip-range">（{ai.range}）</span></div>
                        <p class="ai-tip-desc">{entry.data.aiUsage.description}</p>
                    </div>
                </div>
                );
            })()}

            <!-- word count and reading time -->
            {(postMetaConfig.showWordCount || postMetaConfig.showReadTime) && (
                <div class="flex flex-row text-black/30 dark:text-white/30 gap-5 mb-3 transition onload-animation">
                    {postMetaConfig.showWordCount && (
                        <div class="flex flex-row items-center">
                            <div class="transition h-6 w-6 rounded-md bg-black/5 dark:bg-white/10 text-black/50 dark:text-white/50 flex items-center justify-center mr-2">
                                <Icon name="material-symbols:notes-sharp"></Icon>
                            </div>
                            <div class="text-sm">{remarkPluginFrontmatter.words} 字</div>
                        </div>
                    )}
                    {postMetaConfig.showReadTime && (
                        <div class="flex flex-row items-center">
                            <div class="transition h-6 w-6 rounded-md bg-black/5 dark:bg-white/10 text-black/50 dark:text-white/50 flex items-center justify-center mr-2">
                                <Icon name="material-symbols:schedule-outline-sharp"></Icon>
                            </div>
                            <div class="text-sm">
                                {remarkPluginFrontmatter.minutes} 分钟
                            </div>
                        </div>
                    )}
                </div>
            )}

            <!-- title -->
            <div class="relative onload-animation pr-6">
                <div
                    data-pagefind-body data-pagefind-weight="10" data-pagefind-meta="title"
                    class="transition w-full block font-bold mb-3 text-center
                    text-3xl md:text-[2.25rem]/[2.75rem]
                    text-black/90 dark:text-white/90 p-name
                ">
                    {titleParts ? (
                        <>
                            <span class="post-title-text font-bold inline-block relative">{titleParts.prefix}</span>
                            {suffixNewLine ? <br /> : <span class="font-bold">{titleParts.separator}</span>}
                            <span class="font-normal font-serif" style={`opacity: ${suffixOpacity}; font-size: 1.5rem;`}>{titleParts.suffix}</span>
                        </>
                    ) : (
                        <span class="post-title-text inline-block relative">{entry.data.title}</span>
                    )}
                </div>
            </div>

            <!-- metadata -->
            <div class="onload-animation pr-6">
                <PostMetadata
                        class="mb-5 justify-center"
                        published={entry.data.published}
                        updated={entry.data.updated}
                        tags={entry.data.tags}
                        category={entry.data.category}
                ></PostMetadata>
            </div>
            {!entry.data.image && <div class="border-[var(--line-divider)] border-dashed border-b-[1px] mb-5 onload-animation"></div>}

            <!-- always show cover as long as it has one -->

            {entry.data.image &&
                <ImageWrapper id="post-cover" src={entry.data.image} basePath={path.join("content/posts/", getDir(entry.id))} class="mb-8 rounded-xl banner-container onload-animation"/>
            }


            {(() => {
                const base = "mb-6 markdown-content onload-animation e-content";
                const cls = entry.data.serif === true ? base + " font-serif" : base;
                return <Markdown class={cls}>
                    <Content />
                </Markdown>;
            })()}

            {licenseConfig.enable && <License title={entry.data.title} slug={entry.slug} pubDate={entry.data.published} class="mb-6 rounded-xl license-container onload-animation"></License>}

        </div>
    </div>

    <!-- Comments Section - Separate Card -->
    <div id="comment-section" class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4">
        <div class="card-base z-10 px-4 md:px-9 py-6 relative w-full">
            <LikeButton client:load />
            <Twikoo class="onload-animation"></Twikoo>
        </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between mb-4 gap-4 overflow-hidden w-full">
        <a href={entry.data.nextSlug ? getPostUrlBySlug(entry.data.nextSlug) : "#"}
           class:list={["w-full font-bold overflow-hidden active:scale-95", {"pointer-events-none": !entry.data.nextSlug}]}>
            {entry.data.nextSlug && <div class="btn-card rounded-2xl w-full h-[3.75rem] max-w-full px-4 flex items-center !justify-start gap-4" >
                <Icon name="material-symbols:chevron-left-sharp" class="text-[2rem] text-[var(--primary)]" />
                <div class="overflow-hidden transition overflow-ellipsis whitespace-nowrap max-w-[calc(100%_-_3rem)] text-black/75 dark:text-white/75">
                    {nextTitleParts ? (
                        <>
                            <span class="font-bold">{nextTitleParts.prefix}</span>
                            <span class="font-bold">{nextTitleParts.separator}</span>
                            <span class="font-normal" style={`opacity: ${suffixOpacity}`}>{nextTitleParts.suffix}</span>
                        </>
                    ) : (
                        entry.data.nextTitle
                    )}
                </div>
            </div>}
        </a>

        <a href={entry.data.prevSlug ? getPostUrlBySlug(entry.data.prevSlug) : "#"}
           class:list={["w-full font-bold overflow-hidden active:scale-95", {"pointer-events-none": !entry.data.prevSlug}]}>
            {entry.data.prevSlug && <div class="btn-card rounded-2xl w-full h-[3.75rem] max-w-full px-4 flex items-center !justify-end gap-4">
                <div class="overflow-hidden transition overflow-ellipsis whitespace-nowrap max-w-[calc(100%_-_3rem)] text-black/75 dark:text-white/75">
                    {prevTitleParts ? (
                        <>
                            <span class="font-bold">{prevTitleParts.prefix}</span>
                            <span class="font-bold">{prevTitleParts.separator}</span>
                            <span class="font-normal" style={`opacity: ${suffixOpacity}`}>{prevTitleParts.suffix}</span>
                        </>
                    ) : (
                        entry.data.prevTitle
                    )}
                </div>
                <Icon name="material-symbols:chevron-right-sharp" class="text-[2rem] text-[var(--primary)]" />
            </div>}
        </a>
    </div>

</MainGridLayout>

<style>
    /* AI usage bookmark */
    .ai-mark {
        position: absolute;
        top: 0;
        right: 0.75rem;
        z-index: 50;
    }
    .ai-mark-body {
        width: 2.25rem;
        padding: 0.625rem 0.375rem 1.5rem;
        background: var(--badge-bg);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        clip-path: polygon(0 0, 100% 0, 100% 100%, 50% calc(100% - 14px), 0 100%);
        cursor: default;
    }
    .ai-mark-icon,
    .ai-mark-text {
        color: var(--badge-content);
    }
    .ai-mark-text {
        writing-mode: vertical-rl;
        text-orientation: mixed;
        font-size: 0.875rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        line-height: 1;
    }
    .ai-mark-tip {
        position: absolute;
        right: calc(100% + 8px);
        top: 0.75rem;
        width: 13rem;
        background: var(--card-bg);
        border: 1px solid var(--btn-card-bg-active);
        border-radius: var(--radius-medium);
        padding: 0.75rem 0.9rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
        opacity: 0;
        visibility: hidden;
        transform: translateX(6px);
        transition: opacity 0.18s ease, visibility 0.18s ease, transform 0.18s ease;
        pointer-events: none;
    }
    .ai-mark:hover .ai-mark-tip {
        opacity: 1;
        visibility: visible;
        transform: translateX(0);
        pointer-events: auto;
    }
    .ai-tip-level {
        font-size: 0.92rem;
        font-weight: 700;
        color: var(--badge-content);
        margin-bottom: 0.3rem;
    }
    .ai-tip-range {
        font-size: 0.78rem;
        font-weight: 400;
        opacity: 0.65;
    }
    .ai-tip-desc {
        font-size: 0.92rem;
        color: var(--btn-content);
        line-height: 1.6;
        margin: 0;
    }

    .post-title-text {
        z-index: 0;
        &::after {
            content: '';
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            left: -1rem;
            width: calc(100% + 1.9rem);
            height: 1.1rem;
            background: var(--primary);
            opacity: 0.3;
            filter: url(#xerox);
            z-index: -1;
        }
    }
</style>
